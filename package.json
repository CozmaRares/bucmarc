{
    "name": "bucmarc",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "format": "prettier --write .",
        "dev": "bun run src/index.ts",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "start": "bun dist/index.js",
        "typecheck": "tsc --noEmit",
        "knip": "SKIP_ENV_VALIDATION=true knip",
        "check": "bun run typecheck && bun run knip",
        "build": "bun run check && bun build src/index.ts --outdir=dist --target=bun"
    },
    "devDependencies": {
        "@types/bun": "1.3.14",
        "@types/node": "26.1.0",
        "drizzle-kit": "0.31.10",
        "knip": "6.24.0",
        "prettier": "3.8.3"
    },
    "peerDependencies": {
        "typescript": "6.0.3"
    },
    "dependencies": {
        "@clerk/hono": "0.1.33",
        "@hono/zod-validator": "0.8.0",
        "@libsql/client": "0.17.3",
        "@t3-oss/env-core": "0.13.11",
        "chalk": "5.6.2",
        "drizzle-orm": "0.45.2",
        "hono": "4.12.23",
        "neverthrow": "8.2.0",
        "zod": "4.4.3"
    }
}
