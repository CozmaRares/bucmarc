{
    "name": "bucmarc",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "format": "prettier --write .",
        "issues:report": "bun run scripts/issue-report.ts",
        "dev": "bun run src/index.ts",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "start": "bun dist/index.js",
        "typecheck": "tsc --noEmit",
        "build": "bun run typecheck && bun build src/index.ts --outdir=dist --target=bun"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "drizzle-kit": "^0.31.10",
        "prettier": "^3.8.3"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@clerk/backend": "^3.5.0",
        "@clerk/hono": "^0.1.33",
        "@hono/zod-validator": "^0.8.0",
        "@libsql/client": "^0.17.3",
        "@t3-oss/env-core": "^0.13.11",
        "drizzle-orm": "^0.45.2",
        "hono": "^4.12.23",
        "neverthrow": "^8.2.0",
        "zod": "^4.4.3"
    }
}
